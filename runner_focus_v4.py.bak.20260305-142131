# ---- PID lock ----
LOCKFILE = PIDS / "runner_focus_v3.pid"

def acquire_lock():
    PIDS.mkdir(parents=True, exist_ok=True)
    if LOCKFILE.exists():
        old = (LOCKFILE.read_text(encoding="utf-8", errors="ignore").strip() or "")
        if old.isdigit():
            try:
                os.kill(int(old), 0)
                raise SystemExit(f"runner_focus_v3 already running pid={old}")
            except OSError:
                pass
    LOCKFILE.write_text(str(os.getpid()), encoding="utf-8")

def release_lock():
    try:
        if LOCKFILE.exists():
            LOCKFILE.unlink()
    except Exception:
        pass

def now_ts(): return time.strftime("%Y-%m-%d %H:%M:%S")

def log(msg: str):
    LOGS.mkdir(parents=True, exist_ok=True)
    RUNLOG.open("a", encoding="utf-8").write(f"{now_ts()}  {msg}\n")

def ensure_dirs():
    for p in (INBOX, BIGBOX, FACTS, POSTS, QUEUE, JUNK, ARCHIVE, LOGS, STATE, PIDS):
        p.mkdir(parents=True, exist_ok=True)

def load_json(path: Path, default):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        pass
    return default

def save_json(path: Path, obj):
    path.write_text(json.dumps(obj, indent=2, ensure_ascii=False), encoding="utf-8")

def sha256_bytes(b: bytes) -> str:
    h = hashlib.sha256(); h.update(b); return h.hexdigest()

def sha256_text(s: str) -> str:
    return sha256_bytes((s or "").encode("utf-8", errors="ignore"))

def clean_filename(name: str) -> str:
    name = re.sub(r"[^\w\-.]+", "_", (name or "").strip())
    name = re.sub(r"_+", "_", name)
    return name[:160] if len(name) > 160 else name

def url_domain(url: str) -> str:
    try: return urlparse(url).netloc.lower()
    except Exception: return ""

def allowed_url(url: str) -> bool:
    d = url_domain(url)
    return bool(d) and any(d == dom or d.endswith("." + dom) for dom in DOMAINS)

def ext_of_url(url: str) -> str:
    path = urlparse(url).path
    m = re.search(r"\.([A-Za-z0-9]{1,6})$", path)
    return ("." + m.group(1).lower()) if m else ""

def request(url: str, method="GET", data=None, headers=None):
    h = {"User-Agent": UA}
    if headers: h.update(headers)
    return urllib.request.Request(url, method=method, data=data, headers=h)

def fetch(url: str) -> tuple[int, bytes, dict]:
    last_err = None
    for attempt in range(1, MAX_RETRIES + 1):
        try:
            req = request(url)
            with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT) as r:
                code = getattr(r, "status", 200) or 200
                body = r.read()
                headers = dict(r.headers.items()) if hasattr(r, "headers") else {}
                return code, body, headers
        except urllib.error.HTTPError as e:
            last_err = e
            if attempt < MAX_RETRIES:
                time.sleep((BACKOFF_BASE ** attempt) + random.random())
                continue
            raise
        except Exception as e:
            last_err = e
            if attempt < MAX_RETRIES:
                time.sleep((BACKOFF_BASE ** attempt) + random.random())
                continue
            raise
    raise last_err if last_err else RuntimeError("fetch failed")

def is_pdf_url(url: str, headers=None) -> bool:
    if ext_of_url(url) == ".pdf": return True
    if headers:
        ct = (headers.get("Content-Type") or headers.get("content-type") or "").lower()
        if "application/pdf" in ct: return True
    return False

def extract_links(html: str, base: str) -> list[str]:
    links = []
    for m in re.finditer(r'href\s*=\s*["\']([^"\']+)["\']', html, re.I):
        href = m.group(1).strip()
        if not href or href.startswith("#") or href.startswith("mailto:") or href.startswith("javascript:"):
            continue
        links.append(urljoin(base, href))
    return links

# ---- Focus gate: allow revenue + star bonds, block form/DMV floods ----
FOCUS_ALLOW = [
    # revenue + tax core
    r"revenue", r"tax", r"taxes", r"receipt", r"receipts", r"collection", r"collections",
    r"withholding", r"sales tax", r"income tax", r"corporate", r"severance",
    r"estimate", r"estimated", r"forecast", r"projection",

    # Kansas-specific revenue docs
    r"monthly", r"january", r"february", r"march", r"april", r"may", r"june", r"july",
    r"august", r"september", r"october", r"november", r"december",
    r"comparison report", r"consensus", r"cas", r"general fund", r"sgf",

    # STAR bonds / economic development
    r"star", r"star bond", r"starbond", r"bond", r"bonds"
]
FOCUS_BLOCK = [
    # keep blocking the giant non-revenue floods
    r"drivered", r"dmv", r"cdl", r"handbook", r"reciprocity",
    r"clerk", r"pvd", r"apprais", r"classcode", r"motor",
    r"refundrequest", r"fein", r"abatementprocess", r"appealsprocess",
    r"alcoholactions", r"imposedactions", r"pvdrs", r"cadstandard", r"mappingspecs",

    # common form IDs that aren't revenue intel
    r"\babc\d+\b", r"\bcm\d+\b", r"\bdc\d+\b", r"\bdo\d+\b",

    # maps / directories
    r"map", r"directory", r"contactlist"
]
def should_save_pdf(url: str, filename: str) -> bool:
    s = (url + " " + (filename or "")).lower()
    for pat in FOCUS_BLOCK:
        if re.search(pat, s): return False
    for pat in FOCUS_ALLOW:
        if re.search(pat, s): return True
    return False

def save_pdf_bytes(url: str, b: bytes, seen_hashes: dict, seen_pdfs: dict) -> str:
    base = Path(urlparse(url).path).name or "download.pdf"
    if not base.lower().endswith(".pdf"): base += ".pdf"
    base = clean_filename(base)

    if not should_save_pdf(url, base):
        log(f"SKIP {base} not focus")
        return ""

    h = sha256_bytes(b)
    if h in seen_hashes:
        seen_pdfs[url] = seen_hashes[h]
        return ""

    out = INBOX / base
    if out.exists():
        out = INBOX / f"{out.stem}_{h[:8]}{out.suffix}"

    out.write_bytes(b)
    seen_hashes[h] = out.name
    seen_pdfs[url] = out.name
    log(f"SAVED {out.name} ({len(b)} bytes) <- {url}")
    return out.name

def http_post_json(url: str, payload: dict, timeout=300) -> dict:
    data = json.dumps(payload).encode("utf-8")
    req = request(url, method="POST", data=data, headers={"Content-Type":"application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read().decode("utf-8", errors="replace"))

def ollama_generate(prompt: str, timeout=600) -> str:
    resp = http_post_json(f"{OLLAMA_BASE}/api/generate", {
        "model": MODEL, "prompt": prompt, "stream": False
    }, timeout=timeout)
    return (resp.get("response") or "").strip()

def pdf_to_text(path: Path) -> str:
    import fitz
    doc = fitz.open(str(path))
    chunks = []
    for i, page in enumerate(doc, start=1):
        txt = (page.get_text("text") or "").replace("\x00", "")
        chunks.append(f"\n\n[PAGE {i}]\n{txt}")
    out = "\n".join(chunks).strip()
    return out if out else "[NO_TEXT_EXTRACTED]"

def chunk_text(s: str, max_chars: int) -> list[str]:
    s = (s or "").strip()
    if len(s) <= max_chars: return [s]
    parts = re.split(r"\n{2,}", s)
    chunks, cur = [], ""
    for p in parts:
        p = p.strip()
        if not p: continue
        if len(cur) + len(p) + 2 <= max_chars:
            cur = (cur + "\n\n" + p).strip()
        else:
            if cur: chunks.append(cur)
            cur = p[:max_chars]
    if cur: chunks.append(cur)
    return chunks

FACT_SCHEMA = r'''
Return JSON:
{
  "program_type": "STAR_BOND" | "REVENUE_REPORT" | "BUDGET" | "AUDIT" | "OTHER",
  "title": string|null,
  "jurisdiction": "Kansas"|null,
  "key_numbers": [
    { "label": string, "value": number, "unit": "USD"|"PERCENT"|"OTHER", "year": number|null }
  ],
  "events": [
    { "date": string|null, "year": number|null, "description": string }
  ],
  "evidence": [
    { "quote": string, "note": string }
  ]
}
'''

def extract_facts(text: str) -> dict:
    original_len = len(text or "")
    if original_len > MAX_TOTAL_CHARS:
        head_len = int(MAX_TOTAL_CHARS * 0.65)
        tail_len = MAX_TOTAL_CHARS - head_len
        text = (text or "")[:head_len] + "\n\n[...TRUNCATED...]\n\n" + (text or "")[-tail_len:]

    chunks = chunk_text(text, MAX_CHARS_PER_CHUNK)
    if len(chunks) > MAX_CHUNKS:
        chunks = chunks[:MAX_CHUNKS]

    partials = []
    for i, ch in enumerate(chunks, start=1):
        log(f"Ollama chunk {i}/{len(chunks)} start chars={len(ch)}")
        prompt = f"""You extract facts from TEXT. Output JSON only.

Rules:
- Don't guess.
- Evidence quotes <= 20 words and verbatim.
- Focus on Kansas tax revenue and STAR bonds.

{FACT_SCHEMA}

TEXT:
\"\"\"{ch}\"\"\"
"""
        raw = ollama_generate(prompt, timeout=900)
        try:
            partials.append(json.loads(raw))
            log(f"Ollama chunk {i}/{len(chunks)} done bytes={len(raw.encode('utf-8', errors='ignore'))}")
        except Exception:
            partials.append({"program_type":"OTHER","title":None,"jurisdiction":"Kansas","key_numbers":[],"events":[],"evidence":[]})

    # merge: keep first title, concat unique lists
    merged = {"program_type":"OTHER","title":None,"jurisdiction":"Kansas","key_numbers":[],"events":[],"evidence":[]}
    pref = {"STAR_BOND":4,"REVENUE_REPORT":3,"BUDGET":2,"AUDIT":2,"OTHER":1}
    for p in partials:
        pt = p.get("program_type","OTHER")
        if pref.get(pt,1) > pref.get(merged["program_type"],1): merged["program_type"]=pt
        if not merged["title"] and isinstance(p.get("title"), str) and p["title"].strip(): merged["title"]=p["title"].strip()

    def uniq_merge(key):
        seen=set(); out=[]
        for p in partials:
            for v in (p.get(key) or []):
                sig=json.dumps(v, sort_keys=True, ensure_ascii=False)
                if sig in seen: continue
                seen.add(sig); out.append(v)
        merged[key]=out

    for k in ["key_numbers","events","evidence"]:
        uniq_merge(k)

    merged["evidence"] = (merged.get("evidence") or [])[:8]
    return merged

def score_facts(f: dict) -> int:
    score=0
    if f.get("program_type") in ("STAR_BOND","REVENUE_REPORT","BUDGET","AUDIT"): score += 3
    if f.get("title"): score += 1
    score += min(4, len(f.get("key_numbers") or []))
    score += min(2, len(f.get("events") or []))
    if (f.get("evidence") or []): score += 1
    return score

def make_post(facts: dict, source_url: str, pdf_name: str) -> str:
    ev = facts.get("evidence") or []
    e1 = ev[0].get("quote","") if len(ev)>0 and isinstance(ev[0],dict) else ""
    e2 = ev[1].get("quote","") if len(ev)>1 and isinstance(ev[1],dict) else ""

    prompt = f"""Write a short post (<{MAX_POST_CHARS} chars) about Kansas tax revenue or STAR bonds.

Hard rules:
- Must include 1Ã¢â‚¬â€œ2 short verbatim evidence quotes (in quotes).
- Must end with: Source: {source_url}
- Neutral tone. No guessing. If not enough evidence, output empty.

Title: {facts.get("title") or pdf_name}
Type: {facts.get("program_type")}

Key numbers:
{json.dumps(facts.get("key_numbers") or [], ensure_ascii=False)}

Events:
{json.dumps(facts.get("events") or [], ensure_ascii=False)}

Allowed evidence quotes:
1) {e1}
2) {e2}

Now write the post.
Source: {source_url}
"""
    out = ollama_generate(prompt, timeout=600).strip()
    if not out: return ""
    if f"Source: {source_url}" not in out: return ""
    if '"' not in out and "Ã¢â‚¬Å“" not in out and "Ã¢â‚¬Â" not in out: return ""
    return out[:MAX_POST_CHARS].rstrip()

def pick_files(folder: Path, limit: int) -> list:
    files = [p for p in folder.iterdir() if p.is_file() and p.suffix.lower()==".pdf"]
    files.sort(key=lambda p: p.stat().st_mtime)
    return files[:limit]

def archive_file(src: Path):
    ts = time.strftime("%Y%m%d-%H%M%S")
    dst = ARCHIVE / f"{src.stem}.{ts}{src.suffix}"
    shutil.move(str(src), str(dst))
    return dst

def queue_post(post_text: str, pdf_name: str, seen_posthash: dict) -> str:
    h = sha256_text(post_text)
    if h in seen_posthash: return ""
    QUEUE.mkdir(parents=True, exist_ok=True)
    out = QUEUE / f"{Path(pdf_name).stem}.post.txt"
    if out.exists(): out = QUEUE / f"{Path(pdf_name).stem}_{h[:8]}.post.txt"
    out.write_text(post_text, encoding="utf-8")
    seen_posthash[h]=out.name
    return out.name

def crawl_cycle(seen_urls: set, seen_pdfs: dict, seen_hashes: dict) -> int:
    q = list(SEEDS); pages=0; saved=0
    while q and pages < CRAWL_PAGES_PER_CYCLE:
        url = q.pop(0)
        if url in seen_urls: continue
        if not allowed_url(url): continue
        ext = ext_of_url(url)
        if ext and ext in SKIP_EXT: continue
        seen_urls.add(url)

        try:
            code, body, headers = fetch(url)
            pages += 1

            if is_pdf_url(url, headers):
                if url in seen_pdfs: continue
                if save_pdf_bytes(url, body, seen_hashes, seen_pdfs): saved += 1
                continue

            ct = (headers.get("Content-Type") or headers.get("content-type") or "").lower()
            sniff = body[:2000].decode("utf-8", errors="ignore").lower()
            if "text/html" not in ct and "<html" not in sniff: continue

            html = body.decode("utf-8", errors="replace")
            links = extract_links(html, url)

            page_links = [u for u in links if allowed_url(u) and ext_of_url(u) not in SKIP_EXT]
            pdf_links  = [u for u in links if allowed_url(u) and (ext_of_url(u)==".pdf" or ".pdf" in u.lower())]

            for u in page_links[:30]:
                if u not in seen_urls: q.append(u)

            for pu in pdf_links[:30]:
                if pu in seen_pdfs: continue
                try:
                    c2,b2,h2 = fetch(pu)
                    if is_pdf_url(pu, h2) or pu.lower().endswith(".pdf"):
                        if save_pdf_bytes(pu, b2, seen_hashes, seen_pdfs): saved += 1
                except Exception as e:
                    log(f"ERROR fetch pdf {pu}: {repr(e)}")
        except Exception as e:
            log(f"ERROR fetch {url}: {repr(e)}")

    log(f"CRAWL saved {saved} pdfs")
    return saved

def process_one(pdf_path: Path, source_url: str, seen_posthash: dict):
    try:
        import fitz  # ensure installed
    except Exception:
        log(f"PROCESS ERROR {pdf_path.name}: PyMuPDF missing")
        archive_file(pdf_path); return

    text = pdf_to_text(pdf_path)
    facts = extract_facts(text)
    score = score_facts(facts)

    (FACTS / (pdf_path.stem + ".json")).write_text(json.dumps(facts, indent=2, ensure_ascii=False), encoding="utf-8")

    if REQUIRE_EVIDENCE and not (facts.get("evidence") or []):
        log(f"SKIP {pdf_path.name} no evidence"); archive_file(pdf_path); return
    if score < POST_SCORE_MIN:
        log(f"SKIP {pdf_path.name} score={score} below threshold"); archive_file(pdf_path); return

    post = make_post(facts, source_url, pdf_path.name)
    if not post.strip():
        log(f"SKIP {pdf_path.name} writer empty"); archive_file(pdf_path); return

    queued = queue_post(post, pdf_path.name, seen_posthash)
    if queued: log(f"QUEUED {queued}")
    archive_file(pdf_path)

def cycle_once(seen_urls, seen_pdfs, seen_hashes, seen_posthash):
    crawl_cycle(seen_urls, seen_pdfs, seen_hashes)

    # triage big
    for p in list(INBOX.glob("*.pdf")):
        try:
            if p.stat().st_size >= BIG_BYTES:
                p.replace(BIGBOX / p.name)
        except Exception:
            pass

    # process small
    for p in pick_files(INBOX, PROCESS_PER_CYCLE):
        url = next((u for u,nm in seen_pdfs.items() if nm == p.name), "UNKNOWN_URL")
        process_one(p, url, seen_posthash)

    # process big
    for p in pick_files(BIGBOX, BIG_PER_CYCLE):
        url = next((u for u,nm in seen_pdfs.items() if nm == p.name), "UNKNOWN_URL")
        process_one(p, url, seen_posthash)

def main():
    ensure_dirs()
    acquire_lock()
    try:
        # sanity check Ollama
        req = request(f"{OLLAMA_BASE}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=10) as r:
            _ = json.loads(r.read().decode("utf-8", errors="replace"))

        seen_urls_list = load_json(SEEN_URLS, [])
        seen_urls = set(seen_urls_list if isinstance(seen_urls_list, list) else [])
        seen_pdfs = load_json(SEEN_PDFS, {})
        if not isinstance(seen_pdfs, dict): seen_pdfs = {}
        seen_hashes = load_json(SEEN_HASHES, {})
        if not isinstance(seen_hashes, dict): seen_hashes = {}
        seen_posthash = load_json(SEEN_POSTHASH, {})
        if not isinstance(seen_posthash, dict): seen_posthash = {}

        log(f"RUNNER start domains={DOMAINS} seeds={SEEDS} model={MODEL} ollama={OLLAMA_BASE}")

        cmd = (sys.argv[1] if len(sys.argv) > 1 else "loop").lower()
        if cmd == "once":
            cycle_once(seen_urls, seen_pdfs, seen_hashes, seen_posthash)
            save_json(SEEN_URLS, sorted(seen_urls))
            save_json(SEEN_PDFS, seen_pdfs)
            save_json(SEEN_HASHES, seen_hashes)
            save_json(SEEN_POSTHASH, seen_posthash)
            return

        while True:
            cycle_once(seen_urls, seen_pdfs, seen_hashes, seen_posthash)
            save_json(SEEN_URLS, sorted(seen_urls))
            save_json(SEEN_PDFS, seen_pdfs)
            save_json(SEEN_HASHES, seen_hashes)
            save_json(SEEN_POSTHASH, seen_posthash)
            time.sleep(max(10, INTERVAL_SEC))
    finally:
        release_lock()

if __name__ == "__main__":
    main()
def http_post_json(url: str, payload: dict, timeout=300) -> dict:
    data = json.dumps(payload).encode("utf-8")
    req = request(url, method="POST", data=data, headers={"Content-Type":"application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read().decode("utf-8", errors="replace"))

def ollama_generate(prompt: str) -> str:
    resp = http_post_json(f"{OLLAMA_BASE}/api/generate", {
        "model": MODEL,
        "prompt": prompt,
        "stream": False
    }, timeout=600)
    return (resp.get("response") or "").strip()

def pdf_to_text(path: Path) -> str:
    try:
        import fitz  # PyMuPDF
    except Exception as e:
        raise RuntimeError("PyMuPDF not installed. Run: python -m pip install pymupdf") from e

    doc = fitz.open(str(path))
    chunks = []
    for i, page in enumerate(doc, start=1):
        txt = (page.get_text("text") or "").replace("\x00", "")
        chunks.append(f"\n\n[PAGE {i}]\n{txt}")
    out = "\n".join(chunks).strip()
    return out if out else "[NO_TEXT_EXTRACTED]"

def chunk_text(s: str, max_chars: int = 9000) -> list[str]:
    s = s.strip()
    if len(s) <= max_chars:
        return [s]
    # naive paragraph split
    parts = re.split(r"\n{2,}", s)
    chunks, cur = [], ""
    for p in parts:
        p = p.strip()
        if not p:
            continue
        if len(cur) + len(p) + 2 <= max_chars:
            cur = (cur + "\n\n" + p).strip()
        else:
            if cur:
                chunks.append(cur)
            cur = p[:max_chars]  # hard cap
    if cur:
        chunks.append(cur)
    return chunks

FACT_SCHEMA = r'''
Return JSON with exactly this top-level shape:
{
  "program_type": "STAR_BOND" | "BILL" | "FISCAL_NOTE" | "AUDIT" | "NEWS" | "OTHER",
  "title": string|null,
  "jurisdiction": "Kansas"|null,
  "locations": [string],
  "entities": [
    { "name": string, "type": "PERSON"|"ORG"|"GOV_BODY"|"PROJECT"|"OTHER" }
  ],
  "key_numbers": [
    { "label": string, "value": number, "unit": "USD"|"PERCENT"|"JOBS"|"YEAR"|"OTHER", "year": number|null }
  ],
  "events": [
    { "date": string|null, "year": number|null, "description": string }
  ],
  "evidence": [
    { "quote": string, "note": string }
  ],
  "uncertainties": [string],
  "recommended_next_queries": [string]
}
'''

def extract_facts_fulltext(text: str, max_chars_per_chunk: int = 9000) -> dict:
    """
    Chunk fulltext and extract structured facts with Ollama.
    IMPORTANT: keep 'TEXT:' inside the prompt string; do not place it as Python code.
    """
    chunks = chunk_text(text, max_chars=max_chars_per_chunk)
    log(f"CHUNK total_chars={len(text)} chunks={len(chunks)}")

    partials = []
    for i, ch in enumerate(chunks, start=1):
        log(f"Ollama chunk {i}/{len(chunks)} start chars={len(ch)}")
        prompt = f'''You are an information extraction engine.
Output MUST be valid JSON only. No markdown. No extra text.

Task: extract Kansas public-policy / public-finance facts from the TEXT.

Rules:
- If unknown, use null.
- Use numbers for numeric fields.
- Do not guess; only extract what is in the TEXT.
- Keep evidence quotes short (<= 20 words) and verbatim.

{FACT_SCHEMA}

TEXT:
"""{ch}"""
'''
        raw = ollama_generate(prompt)
        try:
            partials.append(json.loads(raw))
            log(f"Ollama chunk {i}/{len(chunks)} done bytes={len(raw.encode('utf-8', errors='ignore'))}")
        except Exception:
            partials.append({
                "program_type": "OTHER",
                "title": None,
                "jurisdiction": "Kansas",
                "locations": [],
                "entities": [],
                "key_numbers": [],
                "events": [],
                "evidence": [],
                "uncertainties": ["chunk_json_parse_failed"],
                "recommended_next_queries": []
            })

    # merge partials (simple union + best title)
    merged = {
        "program_type": "OTHER",
        "title": None,
        "jurisdiction": "Kansas",
        "locations": [],
        "entities": [],
        "key_numbers": [],
        "events": [],
        "evidence": [],
        "uncertainties": [],
        "recommended_next_queries": []
    }

    pref = {"STAR_BOND":6,"FISCAL_NOTE":5,"BILL":4,"AUDIT":3,"NEWS":2,"OTHER":1}

    def _uniq_extend(key):
        seen = set()
        out = []
        for item in merged[key]:
            s = json.dumps(item, sort_keys=True, ensure_ascii=False)
            if s not in seen:
                seen.add(s); out.append(item)
        merged[key] = out

    for p in partials:
        pt = p.get("program_type") or "OTHER"
        if pref.get(pt, 1) > pref.get(merged["program_type"], 1):
            merged["program_type"] = pt

        if not merged["title"] and p.get("title"):
            merged["title"] = p.get("title")

        for k in ["locations","entities","key_numbers","events","evidence","uncertainties","recommended_next_queries"]:
            try:
                vals = p.get(k) or []
                if isinstance(vals, list):
                    merged[k].extend(vals)
            except Exception:
                pass

    for k in ["locations","entities","key_numbers","events","evidence","uncertainties","recommended_next_queries"]:
        _uniq_extend(k)

    return merged

def score_facts(f: dict) -> int:
    # simple “signal” scoring: numbers + named entities + events + doc type
    score = 0
    pt = f.get("program_type") or "OTHER"
    if pt in ("FISCAL_NOTE","STAR_BOND","BILL","AUDIT"):
        score += 4
    if f.get("title"):
        score += 1
    score += min(4, len(f.get("key_numbers") or []))
    score += min(3, len(f.get("events") or []))
    score += min(2, len(f.get("entities") or []))
    # reward actual money numbers
    for kn in (f.get("key_numbers") or []):
        if isinstance(kn, dict) and (kn.get("unit") == "USD"):
            score += 1
            break
    return score

def make_post(f: dict, source_url: str  = None) -> str:
    header_map = {
        "STAR_BOND": "Kansas STAR Bond Watch — Micro Finding",
        "FISCAL_NOTE": "Kansas Fiscal Note Watch — Micro Finding",
        "BILL": "Kansas Bill Watch — Micro Finding",
        "AUDIT": "Kansas Audit Watch — Micro Finding",
        "NEWS": "Kansas Policy Watch — Micro Finding",
        "OTHER": "Kansas Policy Watch — Micro Finding",
    }
    header = header_map.get(f.get("program_type") or "OTHER", "Kansas Policy Watch — Micro Finding")
    locs = f.get("locations") or []
    loc = ", ".join(locs) if locs else "Kansas"
    lines = [header, f"Location: {loc}"]

    # show up to 3 key numbers
    kns = [x for x in (f.get("key_numbers") or []) if isinstance(x, dict)]
    for kn in kns[:3]:
        label = (kn.get("label") or "Key figure").strip()
        val = kn.get("value")
        unit = kn.get("unit") or "OTHER"
        year = kn.get("year")
        if isinstance(val, (int, float)):
            if unit == "USD":
                v = f"${val:,.0f}"
            elif unit == "PERCENT":
                v = f"{val:.1f}%"
            else:
                v = str(val)
            if year:
                lines.append(f"{label}: {v} ({year})")
            else:
                lines.append(f"{label}: {v}")

    # show a short event if available
    evs = [x for x in (f.get("events") or []) if isinstance(x, dict)]
    if evs:
        desc = (evs[0].get("description") or "").strip()
        if desc:
            lines.append(f"Notable: {desc[:160]}")

    if source_url:
        lines.append(f"Source: {source_url}")
    else:
        lines.append("Source: internal extract (replace with primary PDF link when posting)")
    lines.append("")
    lines.append("(Tone rule: state numbers; no motive; no accusations.)")
    return "\n".join(lines)

def archive_file(src: Path):
    ts = time.strftime("%Y%m%d-%H%M%S")
    dst = ARCHIVE / f"{src.stem}.{ts}{src.suffix}"
    shutil.move(str(src), str(dst))
    return dst

# =========================
# Crawl + triage + process
# =========================
def crawl_cycle(seen_urls: set[str], seen_pdfs: dict, seen_hashes: dict) -> int:
    # BFS-ish crawl: seeds + discovered pages
    queue = list(SEEDS)
    saved_pdfs = 0
    pages = 0

    while queue and pages < CRAWL_PAGES_PER_CYCLE:
        url = queue.pop(0)
        if url in seen_urls:
            continue
        if not allowed_url(url):
            continue

        ext = ext_of_url(url)
        if ext and ext in SKIP_EXT:
            continue

        seen_urls.add(url)
        try:
            code, body, headers = fetch(url)
            pages += 1

            # PDF direct
            if is_pdf_url(url, headers):
                # if already mapped by url, skip fetch/save
                if url in seen_pdfs:
                    continue
                save_pdf_bytes(url, body, seen_hashes, seen_pdfs)
                saved_pdfs += 1
                continue

            # HTML parse
            ct = (headers.get("Content-Type") or headers.get("content-type") or "").lower()
            if "text/html" not in ct and "<html" not in body[:2000].decode("utf-8", errors="ignore").lower():
                continue

            html = body.decode("utf-8", errors="replace")
            links = extract_links(html, url)

            # prioritize PDFs, then same-domain HTML
            pdf_links = [u for u in links if allowed_url(u) and (ext_of_url(u) == ".pdf" or ".pdf" in u.lower())]
            page_links = [u for u in links if allowed_url(u) and ext_of_url(u) not in SKIP_EXT]

            # enqueue some pages
            for u in page_links[:40]:
                if u not in seen_urls:
                    queue.append(u)

            # fetch/save some pdfs quickly
            for pu in pdf_links[:40]:
                if pu in seen_pdfs:
                    continue
                try:
                    c2, b2, h2 = fetch(pu)
                    if is_pdf_url(pu, h2) or pu.lower().endswith(".pdf"):
                        if pu not in seen_pdfs:
                            name = save_pdf_bytes(pu, b2, seen_hashes, seen_pdfs)
                            if name:
                                saved_pdfs += 1
                except urllib.error.HTTPError as e:
                    log(f"HTTPError {e.code} {pu}")
                except urllib.error.URLError as e:
                    log(f"URLError {pu}: {e}")
                except Exception as e:
                    log(f"ERROR fetch {pu}: {repr(e)}")

        except urllib.error.HTTPError as e:
            log(f"HTTPError {e.code} {url}")
        except urllib.error.URLError as e:
            log(f"URLError {url}: {e}")
        except TimeoutError as e:
            log(f"ERROR fetch {url}: timeout({e})")
        except Exception as e:
            log(f"ERROR fetch {url}: {repr(e)}")

    log(f"CRAWL done pages={pages} pdfs_saved={saved_pdfs}")
    return saved_pdfs

def triage_cycle() -> tuple[int,int]:
    moved_big = 0
    moved_skip = 0

    # move oversized into BIGBOX, and skip obvious junk (by ext)
    for p in INBOX.glob("*"):
        if not p.is_file():
            continue
        if p.suffix.lower() != ".pdf":
            continue

        try:
            sz = p.stat().st_size
        except Exception:
            continue

        if sz >= BIG_BYTES:
            dst = BIGBOX / p.name
            try:
                shutil.move(str(p), str(dst))
                moved_big += 1
            except Exception:
                pass

    log(f"TRIAGE moved_big={moved_big} moved_skip={moved_skip}")
    return moved_big, moved_skip

def process_one(pdf_path: Path, source_url: str  = None) -> tuple[bool,int]:
    # returns (posted, score)
    log(f"PROCESS start {pdf_path.name} bytes={pdf_path.stat().st_size}")
    # PQ_HARDJUNK_GATE_V1
    # Hard-junk filter BEFORE any scoring / model work
    if pq_is_hard_junk_filename(getattr(p, "name", str(p))):
        try:
            JUNK.mkdir(parents=True, exist_ok=True)
            out = JUNK / p.name
            if out.exists():
                out = JUNK / f"{{p.stem}}_{{int(time.time())}}{{p.suffix}}"
            p.replace(out)
            log(f"PROCESS junk-hard {p.name} -> junk")
        except Exception as e:
            log(f"PROCESS junk-hard {getattr(p,'name',p)} -> junk FAILED: {e}")
        continue


    text = pdf_to_text(pdf_path)
    if not text or text.strip() in ("", "[NO_TEXT_EXTRACTED]"):
        log(f"PROCESS no-text {pdf_path.name} -> skip")
        archive_file(pdf_path)
        return (False, 0)

    # extract/merge facts across chunks
        # --- prefilter junk BEFORE expensive chunking ---
    try:
        _sample = (text or "")[:12000]
        _reason = low_signal_reason(p.name if "p" in locals() else str(pdf_path), _sample)
        if _reason:
            try:
                junk_dir = ROOT / "junk"
                junk_dir.mkdir(parents=True, exist_ok=True)
                dest = junk_dir / (p.name if "p" in locals() else Path(pdf_path).name)
                try:
                    if dest.exists():
                        dest.unlink()
                except Exception:
                    pass
                Path(pdf_path).replace(dest)
                log(f"PROCESS low-signal {Path(pdf_path).name} reason={_reason} -> junk")
            except Exception as _mv_e:
                log(f"PROCESS low-signal reason={_reason} (move_failed:{_mv_e}) -> skip")
            return
    except Exception as _e:
        log(f"prefilter_error: {_e}")
    facts = extract_facts_fulltext(text, max_chars_per_chunk=9000)

    # score
    score = score_facts(facts)

    # write facts
    out_json = FACTS / (pdf_path.stem + ".json")
    out_json.write_text(json.dumps(facts, indent=2, ensure_ascii=False), encoding="utf-8")

    if score >= POST_SCORE_MIN:
        out_post = POSTS / (pdf_path.stem + ".post.txt")
        out_post.write_text(make_post(facts, source_url=source_url), encoding="utf-8")
        log(f"PROCESS posted {pdf_path.name} score={score} -> {out_post.name}")
        posted = True
    else:
        log(f"PROCESS low-signal {pdf_path.name} score={score} -> skip")
        posted = False

    archive_file(pdf_path)
    return (posted, score)

def pick_files(folder: Path, limit: int) -> list[Path]:
    files = [p for p in folder.iterdir() if p.is_file() and p.suffix.lower() == ".pdf"]
    files.sort(key=lambda p: p.stat().st_mtime)
    return files[:limit]

def cycle_once(seen_urls: set[str], seen_pdfs: dict, seen_hashes: dict) -> tuple[int,int,int]:
    saved = crawl_cycle(seen_urls, seen_pdfs, seen_hashes)
    triage_cycle()

    posted = 0
    skipped = 0

    # Small lane first
    small = pick_files(INBOX, PROCESS_PER_CYCLE)
    for p in small:
        try:
            did_post, score = process_one(p)
            if did_post:
                posted += 1
            else:
                skipped += 1
        except KeyboardInterrupt:
            raise
        except Exception as e:
            log(f"PROCESS ERROR {p.name}: {repr(e)}")
            try:
                archive_file(p)
            except Exception:
                pass
            skipped += 1

    # Big lane (slow drip)
    big = pick_files(BIGBOX, BIG_PER_CYCLE)
    for p in big:
        try:
            did_post, score = process_one(p)
            if did_post:
                posted += 1
            else:
                skipped += 1
        except KeyboardInterrupt:
            raise
        except Exception as e:
            log(f"BIG PROCESS ERROR {p.name}: {repr(e)}")
            try:
                archive_file(p)
            except Exception:
                pass
            skipped += 1

    inbox_count = len([p for p in INBOX.iterdir() if p.is_file() and p.suffix.lower() == ".pdf"])
    log(f"CYCLE done saved={saved} posted={posted} skipped={skipped} inbox={inbox_count}")
    return saved, posted, skipped

def main():
    ensure_dirs()

    # quick api check (GET /api/tags)
    try:
        req = request(f"{OLLAMA_BASE}/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=10) as r:
            _ = json.loads(r.read().decode("utf-8", errors="replace"))
    except Exception as e:
        raise RuntimeError(f"Can't reach Ollama API at {OLLAMA_BASE}. Make sure `ollama serve` is running there.") from e

    seen_urls_list = load_json(SEEN_URLS, [])
    seen_urls = set(seen_urls_list if isinstance(seen_urls_list, list) else [])

    seen_pdfs = load_json(SEEN_PDFS, {})
    if not isinstance(seen_pdfs, dict):
        seen_pdfs = {}

    seen_hashes = load_json(SEEN_HASHES, {})
    if not isinstance(seen_hashes, dict):
        seen_hashes = {}

    log(f"RUNNER start domains={DOMAINS} seeds={SEEDS} model={MODEL} ollama={OLLAMA_BASE}")
    log(f"KNOBS interval={INTERVAL_SEC}s crawl_pages={CRAWL_PAGES_PER_CYCLE} process={PROCESS_PER_CYCLE} big={BIG_PER_CYCLE} post_min={POST_SCORE_MIN} big_bytes={BIG_BYTES}")

    cmd = (sys.argv[1] if len(sys.argv) > 1 else "loop").lower()

    if cmd == "once":
        cycle_once(seen_urls, seen_pdfs, seen_hashes)
        save_json(SEEN_URLS, sorted(seen_urls))
        save_json(SEEN_PDFS, seen_pdfs)
        save_json(SEEN_HASHES, seen_hashes)
        return

    # loop forever
    while True:
        try:
            cycle_once(seen_urls, seen_pdfs, seen_hashes)
        except KeyboardInterrupt:
            log("RUNNER stopped by user")
            save_json(SEEN_URLS, sorted(seen_urls))
            save_json(SEEN_PDFS, seen_pdfs)
            save_json(SEEN_HASHES, seen_hashes)
            raise

        # persist state each cycle
        save_json(SEEN_URLS, sorted(seen_urls))
        save_json(SEEN_PDFS, seen_pdfs)
        save_json(SEEN_HASHES, seen_hashes)

        time.sleep(max(10, INTERVAL_SEC))

if __name__ == "__main__":
    main()





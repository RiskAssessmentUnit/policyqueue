def low_signal_reason(pdf_name: str, text_sample: str) -> str:
    import re
    n = (pdf_name or "").lower()
    t = (text_sample or "").lower()

    for pat in LOW_SIGNAL_NAME_PATTERNS:
        if re.search(pat, n):
            return f"name_match:{pat}"

    map_hits = 0
    for pat in LOW_SIGNAL_TEXT_PATTERNS:
        if re.search(pat, t):
            map_hits += 1

    policy_hits = 0
    for pat in [r'\bfiscal\b', r'\bappropriat', r'\bbudget\b', r'\brevenue\b', r'\bexpenditure\b',
                r'\baudit\b', r'\blegislat', r'\bcommittee\b', r'\bhearing\b', r'\bbill\b', r'\bksa\b']:
        if re.search(pat, t):
            policy_hits += 1

    if map_hits >= 6 and policy_hits <= 1:
        return f"text_mapheavy:map_hits={map_hits},policy_hits={policy_hits}"

    return ""



